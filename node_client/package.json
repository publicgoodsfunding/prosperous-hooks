{
  "name": "@prosperous/client",
  "version": "0.1.0",
  "description": "Node.js bindings for the Prosperous client",
  "main": "index.js",
  "scripts": {
    "build:rust": "cargo build --release -p prosperous-client-native",
    "build:node": "node-gyp configure && node-gyp build",
    "build": "pnpm run build:rust && pnpm run build:node",
    "install": "pnpm run build"
  },
  "gypfile": true,
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^8.0.0"
  }
}
